# 复制为 .env.electron 后执行 npm run electron:dist
# API/WS：打包后请改 release 目录下 app-config.json（与 exe 同目录），无需重新打包
NODE_ENV=production
ENV=/electron
VUE_APP_BASE_API=http://127.0.0.1:8080/api
VUE_APP_WS_URL=ws://127.0.0.1:8080/websocket
VUE_APP_MINIO_BASE_URL=http://127.0.0.1:9000
VUE_APP_ENABLE_REGISTER=true
VUE_APP_ICP_NUMBER=
VUE_APP_ICP_LINK=
VUE_APP_TITLE=校园在线考试系统（学生端）

VUE_APP_CRYPTO_KEY=changeme16byte!!
VUE_APP_CRYPTO_IV=changeme16byte!!
