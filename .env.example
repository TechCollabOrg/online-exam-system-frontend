# 复制为 .env.development / .env.electron 等本地文件（勿提交含真实密钥的版本）。
# Vue CLI 仅会将以 VUE_APP_ 开头的变量打入前端包；前端密钥仍会出现在打包后的 JS 中，仅避免明文躺在 Git 仓库里。

ENV=development
VUE_APP_BASE_API=/api
VUE_APP_WS_URL=ws://127.0.0.1:8080/websocket
VUE_APP_ENABLE_REGISTER=true
VUE_APP_ICP_NUMBER=
VUE_APP_ICP_LINK=
VUE_APP_TITLE=校园在线考试系统

# 须与后端 EXAM_AES_KEY / EXAM_AES_IV 一致，各 16 字符
VUE_APP_CRYPTO_KEY=changeme16byte!!
VUE_APP_CRYPTO_IV=changeme16byte!!
