# just a flag
ENV = '/production'

# base api（若前端与 API 不同域，请改为完整 URL，例如 https://exam.school.edu/api）
VUE_APP_BASE_API = '/api'
# 生产环境 WebSocket；与站点同域时可改为 wss://你的域名/websocket
VUE_APP_WS_URL = 'ws://127.0.0.1:8080/websocket'
# 是否开启注册，API接口也要配置是否开放注册
VUE_APP_ENABLE_REGISTER=true

# 网站备案信息
VUE_APP_ICP_NUMBER='京ICP备XXXXXXXX号'
VUE_APP_ICP_LINK='https://beian.miit.gov.cn/'
# 网站标题
VUE_APP_TITLE='校园在线考试系统'

VUE_APP_CRYPTO_KEY=changeme16byte!!
VUE_APP_CRYPTO_IV=changeme16byte!!
